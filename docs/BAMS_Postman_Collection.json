{
    "info": {
        "_postman_id": "bams-api-collection",
        "name": "BAMS Banking API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\"username\": \"admin\", \"password\": \"admin123\"}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/login"
                        }
                    }
                }
            ]
        },
        {
            "name": "Accounts",
            "item": [
                {
                    "name": "Get Balance",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/accounts/balance"
                        }
                    }
                }
            ]
        }
    ]
}